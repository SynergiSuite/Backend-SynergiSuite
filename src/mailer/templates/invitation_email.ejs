<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Invitation to Join SynergiSuite</title>
    <link href="https://fonts.googleapis.com/css?family=Poppins:200,300,400,500,600,700|Plus+Jakarta+Sans:600,700|Inter:400,500,600" rel="stylesheet">
    <style>
        html,
        body {
            margin: 0 auto !important;
            padding: 0 !important;
            height: 100% !important;
            width: 100% !important;
            background-color: #0A0A0B;
            font-family: 'Inter', sans-serif;
            color: #c7c6ca;
        }
        * {
            -ms-text-size-adjust: 100%;
            -webkit-text-size-adjust: 100%;
        }
        div[style*="margin: 16px 0"] {
            margin: 0 !important;
        }
        table,
        td {
            mso-table-lspace: 0pt !important;
            mso-table-rspace: 0pt !important;
        }
        table {
            border-spacing: 0 !important;
            border-collapse: collapse !important;
            table-layout: fixed !important;
            margin: 0 auto !important;
        }
        a {
            text-decoration: none;
            color: #adc6ff;
            transition: color 0.2s ease;
        }
        a:hover {
            color: #4edea3;
        }
        .main-card {
            background-color: #1d2022;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
        }
        .token-box {
            background-color: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 14px 20px;
            font-family: monospace;
            font-size: 16px;
            color: #4edea3;
            word-break: break-all;
            text-align: center;
        }
        .btn-primary {
            background-color: #0566d9;
            color: #ffffff;
            font-weight: 600;
            border-radius: 16px;
            padding: 12px 24px;
            display: inline-block;
            box-shadow: 0 0 15px rgba(5, 102, 217, 0.4);
        }
        .footer-section {
            background-color: #101415;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            color: #919094;
        }
        .footer-heading {
            color: #e0e3e5;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 16px;
            font-weight: 600;
            margin-top: 0;
            margin-bottom: 12px;
        }
        .footer-section ul {
            padding: 0;
            margin: 0;
            list-style: none;
        }
        .footer-section ul li {
            margin-bottom: 8px;
            font-size: 13px;
        }
        .footer-section ul li a {
            color: #919094;
        }
        .footer-section ul li a:hover {
            color: #adc6ff;
        }
    </style>
</head>
<body width="100%" style="margin: 0; padding: 0 !important; mso-line-height-rule: exactly; background-color: #0A0A0B;">
    <center style="width: 100%; background-color: #0A0A0B; padding: 40px 0;">
        <div style="max-width: 600px; margin: 0 auto; padding: 0 20px;" class="email-container">
            <!-- Header Logo -->
            <table align="center" role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                <tr>
                    <td style="text-align: center; padding-bottom: 32px;">
                        <h1 style="margin: 0; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 26px; font-weight: 700; color: #e0e3e5; letter-spacing: 1.5px; display: inline-flex; align-items: center; gap: 8px;">
                            <span style="display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: #0566d9; box-shadow: 0 0 10px #0566d9;"></span>
                            SynergiSuite
                        </h1>
                    </td>
                </tr>
            </table>

            <!-- Main Body -->
            <table align="center" role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" class="main-card">
                <tr>
                    <td style="padding: 40px 32px;">
                        <!-- Invite Heading -->
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                            <tr>
                                <td style="text-align: center; padding-bottom: 24px;">
                                    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 22px; font-weight: 600; line-height: 1.4; color: #ffffff; margin: 0;">
                                        <%= invited_by %> would like to invite you to join their organization.
                                    </h2>
                                </td>
                            </tr>
                        </table>

                        <!-- Inviter Card Info -->
                        <table role="presentation" border="0" cellpadding="20" cellspacing="0" width="100%" style="background-color: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; margin-bottom: 32px;">
                            <tr>
                                <td align="center" style="padding-bottom: 10px;">
                                    <!-- Avatar Placeholder in Electric Blue -->
                                    <table border="0" cellpadding="0" cellspacing="0" style="margin: 0 auto;">
                                        <tr>
                                            <td align="center" valign="middle" style="background-color: #0566d9; width: 70px; height: 70px; border-radius: 50%; color: #ffffff; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 24px; font-weight: 700; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">
                                                <%= invited_by.charAt(0).toUpperCase() %>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                            <tr>
                                <td align="center" style="padding-top: 0; padding-bottom: 15px;">
                                    <h3 style="margin: 0; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 18px; font-weight: 600; color: #e0e3e5;"><%= invited_by %></h3>
                                    <span style="font-size: 13px; color: #919094; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;"><%= invited_bys_role %> at <%= business %></span>
                                </td>
                            </tr>
                            <tr>
                                <td align="center" style="padding-top: 0; border-top: 1px solid rgba(255, 255, 255, 0.05);">
                                    <p style="margin: 15px 0 0 0; font-size: 15px; line-height: 1.6; color: #c7c6ca; font-style: italic;">
                                        "You've been invited to join the team and collaborate on our secure workspace platforms."
                                    </p>
                                </td>
                            </tr>
                        </table>

                        <!-- Token Code Box -->
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 32px;">
                            <tr>
                                <td align="center" style="padding-bottom: 12px;">
                                    <span style="font-size: 13px; font-weight: 600; text-transform: uppercase; color: #919094; letter-spacing: 1px;">Invitation Token</span>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="token-box">
                                        <%= text %>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td align="center" style="padding-top: 12px;">
                                    <span style="font-size: 12px; color: #919094;">Use this token to complete registration and join the organization.</span>
                                </td>
                            </tr>
                        </table>

                        <!-- Action Button -->
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                            <tr>
                                <td align="center">
                                    <a href="#" class="btn-primary">Join Organization</a>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>

            <!-- Footer Columns -->
            <table align="center" role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-top: 32px; border-radius: 24px; overflow: hidden;" class="footer-section">
                <tr>
                    <td style="padding: 40px 32px;">
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
                            <tr>
                                <!-- About Column -->
                                <td valign="top" width="45%" style="padding-right: 20px;">
                                    <h3 class="footer-heading">About</h3>
                                    <p style="font-size: 13px; line-height: 1.6; margin: 0;">
                                        SynergiSuite is a unified enterprise management platform. Our secure workspace facilitates seamless team collaboration and analytics.
                                    </p>
                                </td>
                                <!-- Contact Column -->
                                <td valign="top" width="30%" style="padding-right: 10px;">
                                    <h3 class="footer-heading">Contact Info</h3>
                                    <ul>
                                        <li>203 Fake St. Mountain View, San Francisco, California, USA</li>
                                        <li>+2 392 3929 210</li>
                                    </ul>
                                </td>
                                <!-- Links Column -->
                                <td valign="top" width="25%">
                                    <h3 class="footer-heading">Useful Links</h3>
                                    <ul>
                                        <li><a href="#">Home</a></li>
                                        <li><a href="#">About</a></li>
                                        <li><a href="#">Services</a></li>
                                        <li><a href="#">Work</a></li>
                                    </ul>
                                </td>
                            </tr>
                        </table>
                        
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-top: 30px; border-top: 1px solid rgba(255, 255, 255, 0.05); padding-top: 20px;">
                            <tr>
                                <td align="center" style="font-size: 12px; color: #46464a;">
                                    No longer want to receive these emails? You can <a href="#" style="color: #adc6ff;">Unsubscribe here</a>.
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </div>
    </center>
</body>
</html>